local HttpService = game:GetService("HttpService")
local fileName = "ESP_Config_Advanced.json"

-- セーブ機能
local function saveConfig()
    local config = {
        ShowNames = _G.ShowNames,
        ShowBoxes = _G.ShowBoxes,
        ShowTracers = _G.ShowTracers,
        ShowSkeletons = _G.ShowSkeletons,
        Colors = {
            Names = {math.floor(_G.Colors.ShowNames.R*255), math.floor(_G.Colors.ShowNames.G*255), math.floor(_G.Colors.ShowNames.B*255)},
            Boxes = {math.floor(_G.Colors.ShowBoxes.R*255), math.floor(_G.Colors.ShowBoxes.G*255), math.floor(_G.Colors.ShowBoxes.B*255)},
            Tracers = {math.floor(_G.Colors.ShowTracers.R*255), math.floor(_G.Colors.ShowTracers.G*255), math.floor(_G.Colors.ShowTracers.B*255)},
            Skeletons = {math.floor(_G.Colors.ShowSkeletons.R*255), math.floor(_G.Colors.ShowSkeletons.G*255), math.floor(_G.Colors.ShowSkeletons.B*255)}
        }
    }
    pcall(function()
        writefile(fileName, HttpService:JSONEncode(config))
    end)
end

-- ロード機能
local function loadConfig()
    pcall(function()
        if isfile(fileName) then
            local data = HttpService:JSONDecode(readfile(fileName))
            if data.ShowNames ~= nil then _G.ShowNames = data.ShowNames end
            if data.ShowBoxes ~= nil then _G.ShowBoxes = data.ShowBoxes end
            if data.ShowTracers ~= nil then _G.ShowTracers = data.ShowTracers end
            if data.ShowSkeletons ~= nil then _G.ShowSkeletons = data.ShowSkeletons end
            
            if data.Colors then
                if data.Colors.Names then _G.Colors.ShowNames = Color3.fromRGB(unpack(data.Colors.Names)) end
                if data.Colors.Boxes then _G.Colors.ShowBoxes = Color3.fromRGB(unpack(data.Colors.Boxes)) end
                if data.Colors.Tracers then _G.Colors.ShowTracers = Color3.fromRGB(unpack(data.Colors.Tracers)) end
                if data.Colors.Skeletons then _G.Colors.ShowSkeletons = Color3.fromRGB(unpack(data.Colors.Skeletons)) end
            end
        end
    end)
end

