local function createColorSlider(colorChannel)
    local btn = Instance.new("TextButton", MainPanel)
    btn.Size = UDim2.new(0, 205, 0, 28)
    btn.Font = Enum.Font.RobotoMono
    btn.TextSize = 11
    btn.BorderSizePixel = 0
    btn.BackgroundColor3 = Color3.fromRGB(22, 22, 25)
    
    local btnCorner = Instance.new("UICorner", btn)
    btnCorner.CornerRadius = UDim.new(0, 6)
    
    local btnStroke = Instance.new("UIStroke", btn)
    btnStroke.Thickness = 1
    btnStroke.Color = Color3.fromRGB(50, 50, 55)
    btnStroke.Transparency = 0.5

    local function updateColorDisplay()
        local activeColor = _G.Colors[currentConfigTarget]
        local r = math.floor(activeColor.R * 255)
        local g = math.floor(activeColor.G * 255)
        local b = math.floor(activeColor.B * 255)
        
        if colorChannel == "R" then
            btn.Text = "  [R] VALUE: " .. r
            btn.TextColor3 = Color3.fromRGB(255, 90, 90)
        elseif colorChannel == "G" then
            btn.Text = "  [G] VALUE: " .. g
            btn.TextColor3 = Color3.fromRGB(90, 255, 90)
        elseif colorChannel == "B" then
            btn.Text = "  [B] VALUE: " .. b
            btn.TextColor3 = Color3.fromRGB(90, 90, 255)
        end
    end

    btn.MouseButton1Click:Connect(function()
        local activeColor = _G.Colors[currentConfigTarget]
        local r = math.floor(activeColor.R * 255)
        local g = math.floor(activeColor.G * 255)
        local b = math.floor(activeColor.B * 255)

        if colorChannel == "R" then r = (r + 25) > 255 and 0 or (r + 25)
        elseif colorChannel == "G" then g = (g + 25) > 255 and 0 or (g + 25)
        elseif colorChannel == "B" then b = (b + 25) > 255 and 0 or (b + 25)
        end

        _G.Colors[currentConfigTarget] = Color3.fromRGB(r, g, b)
        updateColorDisplay()
        saveConfig()
    end)

    task.spawn(function()
        while task.wait(0.1) do
            updateColorDisplay()
        end
    end)
    updateColorDisplay()
end

