local function createToggleButton(text, globalVar)
    local btn = Instance.new("TextButton", MainPanel)
    btn.Size = UDim2.new(0, 190, 0, 36)
    btn.Font = Enum.Font.RobotoMono
    btn.TextSize = 12
    btn.BorderSizePixel = 0
    
    local btnCorner = Instance.new("UICorner", btn)
    btnCorner.CornerRadius = UDim.new(0, 6)
    
    local btnStroke = Instance.new("UIStroke", btn)
    btnStroke.Thickness = 1
    btnStroke.Transparency = 0.6

    local function updateButtonDisplay()
        if _G[globalVar] then
            TweenService:Create(btn, tweenInfo, {BackgroundColor3 = Color3.fromRGB(245, 245, 245)}):Play()
            TweenService:Create(btn, tweenInfo, {TextColor3 = Color3.fromRGB(15, 15, 15)}):Play()
            btnStroke.Color = Color3.fromRGB(255, 255, 255)
            btn.Text = text .. " : ON"
        else
            TweenService:Create(btn, tweenInfo, {BackgroundColor3 = Color3.fromRGB(30, 30, 35)}):Play()
            TweenService:Create(btn, tweenInfo, {TextColor3 = Color3.fromRGB(130, 130, 135)}):Play()
            btnStroke.Color = Color3.fromRGB(70, 70, 75)
            btn.Text = text .. " : OFF"
        end
    end
    
    btn.MouseEnter:Connect(function()
        TweenService:Create(btnStroke, tweenInfo, {Transparency = 0.2}):Play()
    end)
    btn.MouseLeave:Connect(function()
        TweenService:Create(btnStroke, tweenInfo, {Transparency = 0.6}):Play()
    end)
    
    btn.MouseButton1Click:Connect(function()
        _G[globalVar] = not _G[globalVar]
        updateButtonDisplay()
    end)
    
    updateButtonDisplay()
    return btn
end

createToggleButton("NAMES & INFO", "ShowNames")
