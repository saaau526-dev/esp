local ESPCache = {}

local function getESP(v)
    if not ESPCache[v.Name] then
        ESPCache[v.Name] = {
            Box = Drawing.new("Square"),
            Tracer = Drawing.new("Line"),
            Bones = {}
        }
        ESPCache[v.Name].Box.Thickness = 1.5
        ESPCache[v.Name].Box.Filled = false
        ESPCache[v.Name].Box.Transparency = 0.85
        
        ESPCache[v.Name].Tracer.Thickness = 1
        ESPCache[v.Name].Tracer.Transparency = 0.5

        for i = 1, 15 do
            local boneLine = Drawing.new("Line")
            boneLine.Thickness = 1.5
            boneLine.Transparency = 0.7
            boneLine.Visible = false
            table.insert(ESPCache[v.Name].Bones, boneLine)
        end
    end
    return ESPCache[v.Name]
end

local function updateTagText(targetPlayer, tagLabel)
    local char = targetPlayer.Character
    if char and char:FindFirstChild("HumanoidRootPart") and char:FindFirstChild("Humanoid") and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
        local distance = math.floor((plr.Character.HumanoidRootPart.Position - char.HumanoidRootPart.Position).Magnitude)
        local health = math.floor(char.Humanoid.Health)
        tagLabel.Text = string.format("[%s] Name : %s  Health : %d", distance .. "m", targetPlayer.Name, health)
    else
        tagLabel.Text = targetPlayer.Name
    end
    tagLabel.TextColor3 = _G.Colors.ShowNames
end

local LoadCharacter = function(v)
    if v == plr then return end
    repeat wait() until v.Character ~= nil
    v.Character:WaitForChild("Humanoid")
    
    local vHolder = Holder:FindFirstChild(v.Name)
    if not vHolder then return end
    vHolder:ClearAllChildren()
    
    local t = NameTag:Clone()
    t.Name = v.Name .. "NameTag"
    t.Enabled = true
    t.Parent = vHolder
    t.Adornee = v.Character:WaitForChild("Head", 5)
    if not t.Adornee then return end
    
    t.Tag.Name = "TargetTag"
end

local UnloadCharacter = function(v)
    local vHolder = Holder:FindFirstChild(v.Name)
    if vHolder then vHolder:ClearAllChildren() end
    
    if ESPCache[v.Name] then
        pcall(function() ESPCache[v.Name].Box:Remove() end)
        pcall(function() ESPCache[v.Name].Tracer:Remove() end)
        for _, bone in pairs(ESPCache[v.Name].Bones) do
            pcall(function() bone:Remove() end)
        end
        ESPCache[v.Name] = nil
    end
end

local LoadPlayer = function(v)
    if v == plr then return end
    local vHolder = Instance.new("Folder", Holder)
    vHolder.Name = v.Name
    v.CharacterAdded:Connect(function() pcall(LoadCharacter, v) end)
    v.CharacterRemoving:Connect(function() pcall(UnloadCharacter, v) end)
    pcall(LoadCharacter, v)
end

local UnloadPlayer = function(v)
    UnloadCharacter(v)
    local vHolder = Holder:FindFirstChild(v.Name)
    if vHolder then vHolder:Destroy() end
end

for i,v in pairs(players:GetPlayers()) do
    if v ~= plr then task.spawn(function() pcall(LoadPlayer, v) end) end
end

