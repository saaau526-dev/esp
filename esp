local function drawSkeleton(char, esp, onScreen)
    if not onScreen or not _G.ShowSkeletons then 
        for _, bone in pairs(esp.Bones) do bone.Visible = false end
        return 
    end

    local joints = {}
    if char:FindFirstChild("UpperTorso") then
        joints = {
            {"Head", "UpperTorso"}, {"UpperTorso", "LowerTorso"},
            {"UpperTorso", "LeftUpperArm"}, {"LeftUpperArm", "LeftLowerArm"}, {"LeftLowerArm", "LeftHand"},
            {"UpperTorso", "RightUpperArm"}, {"RightUpperArm", "RightLowerArm"}, {"RightLowerArm", "RightHand"},
            {"LowerTorso", "LeftUpperLeg"}, {"LeftUpperLeg", "LeftLowerLeg"}, {"LeftLowerLeg", "LeftFoot"},
            {"LowerTorso", "RightUpperLeg"}, {"RightUpperLeg", "RightLowerLeg"}, {"RightLowerLeg", "RightFoot"}
        }
    elseif char:FindFirstChild("Torso") then
        joints = {
            {"Head", "Torso"}, {"Torso", "Left Arm"}, {"Torso", "Right Arm"},
            {"Torso", "Left Leg"}, {"Torso", "Right Leg"}
        }
    end

    local index = 1
    for _, pair in pairs(joints) do
        local p1, p2 = char:FindFirstChild(pair[1]), char:FindFirstChild(pair[2])
        if p1 and p2 then
            local pos1, os1 = camera:WorldToViewportPoint(p1.Position)
            local pos2, os2 = camera:WorldToViewportPoint(p2.Position)
            if os1 and os2 then
                local boneLine = esp.Bones[index]
                if boneLine then
                    boneLine.From = Vector2.new(pos1.X, pos1.Y)
                    boneLine.To = Vector2.new(pos2.X, pos2.Y)
                    boneLine.Color = _G.Colors.ShowSkeletons
                    boneLine.Visible = true
                    index = index + 1
                end
            end
        end
    end
    for i = index, #esp.Bones do
        esp.Bones[i].Visible = false
    end
end

task.spawn(function()
    while task.wait() do
        for i, v in pairs(players:GetPlayers()) do
            pcall(function()
                local esp = getESP(v)
                
                if v ~= plr and v.Character and v.Character:FindFirstChild("HumanoidRootPart") and v.Character:FindFirstChild("Humanoid") then
                    local hrp = v.Character.HumanoidRootPart
                    local screenPos, onScreen = camera:WorldToViewportPoint(hrp.Position)
                    
                    if v.Character:FindFirstChild("GetReal") then
                        v.Character.GetReal:Destroy()
                    end
                    
                    if onScreen then
                        local head = v.Character:FindFirstChild("Head")
                        local headPos = head and camera:WorldToViewportPoint(head.Position + Vector3.new(0, 0.5, 0)) or screenPos
                        local legPos = camera:WorldToViewportPoint(hrp.Position - Vector3.new(0, 3, 0))
                        
                        local boxHeight = math.abs(headPos.Y - legPos.Y)
                        local boxWidth = boxHeight / 1.5
                        
                        if _G.ShowBoxes then
                            esp.Box.Size = Vector2.new(boxWidth, boxHeight)
                            esp.Box.Position = Vector2.new(screenPos.X - boxWidth / 2, screenPos.Y - boxHeight / 2)
                            esp.Box.Color = _G.Colors.ShowBoxes
                            esp.Box.Visible = true
                        else
                            esp.Box.Visible = false
                        end
                        
                        if _G.ShowTracers then
                            esp.Tracer.Color = _G.Colors.ShowTracers
                            esp.Tracer.From = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y)
                            esp.Tracer.To = Vector2.new(screenPos.X, screenPos.Y)
                            esp.Tracer.Visible = true
                        else
                            esp.Tracer.Visible = false
                        end
                        
                        local vHolder = Holder:FindFirstChild(v.Name)
                        if vHolder then
                            local nameTag = vHolder:FindFirstChild(v.Name .. "NameTag")
                            if nameTag then
                                nameTag.Enabled = _G.ShowNames
                                local targetTag = nameTag:FindFirstChild("TargetTag")
                                if targetTag and _G.ShowNames then
                                    updateTagText(v, targetTag)
                                end
                            end
                        end
                    else
                        esp.Box.Visible = false
                        esp.Tracer.Visible = false
                        local vHolder = Holder:FindFirstChild(v.Name)
                        if vHolder and vHolder:FindFirstChild(v.Name .. "NameTag") then
                            vHolder[v.Name .. "NameTag"].Enabled = false
                        end
                    end
                    drawSkeleton(v.Character, esp, onScreen)
                else
                    esp.Box.Visible = false
                    esp.Tracer.Visible = false
                    for _, bone in pairs(esp.Bones) do bone.Visible = false end
                end
            end)
        end
    end
end)
