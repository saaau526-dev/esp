local players = game:GetService("Players")
local plr = players.LocalPlayer
local camera = workspace.CurrentCamera

local ESPCache = {}

local function getESP(v)
    if not ESPCache[v.Name] then
        ESPCache[v.Name] = {
            Box = Drawing.new("Square"),
            Tracer = Drawing.new("Line")
        }
        ESPCache[v.Name].Box.Thickness = 1.5
        ESPCache[v.Name].Box.Filled = false
        ESPCache[v.Name].Box.Transparency = 0.85
        
        ESPCache[v.Name].Tracer.Thickness = 1
        ESPCache[v.Name].Tracer.Transparency = 0.5
    end
    return ESPCache[v.Name]
end

local function updateTagText(targetPlayer, tagLabel)
    local char = targetPlayer.Character
    if char and char:FindFirstChild("HumanoidRootPart") and char:FindFirstChild("Humanoid") and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
        local distance = math.floor((plr.Character.HumanoidRootPart.Position - char.HumanoidRootPart.Position).Magnitude)
        local health = math.floor(char.Humanoid.Health)
        tagLabel.Text = string.format("[%s] Name : %s  Health : %d", distance .. "m", targetPlayer.Name, health)
    else
        tagLabel.Text = targetPlayer.Name
    end
end

local LoadCharacter = function(v)
    if v == plr then return end
    repeat wait() until v.Character ~= nil
    v.Character:WaitForChild("Humanoid")
    
    local vHolder = Holder:FindFirstChild(v.Name)
    if not vHolder then return end
    vHolder:ClearAllChildren()
    
    local t = NameTag:Clone()
    t.Name = v.Name .. "NameTag"
    t.Enabled = true
    t.Parent = vHolder
    t.Adornee = v.Character:WaitForChild("Head", 5)
    if not t.Adornee then return end
    
    t.Tag.TextColor3 = _G.ESPColor
    t.Tag.Name = "TargetTag"
end

local UnloadCharacter = function(v)
    local vHolder = Holder:FindFirstChild(v.Name)
    if vHolder then vHolder:ClearAllChildren() end
    
    if ESPCache[v.Name] then
        ESPCache[v.Name].Box:Remove()
        ESPCache[v.Name].Tracer:Remove()
        ESPCache[v.Name] = nil
    end
end

local LoadPlayer = function(v)
    if v == plr then return end
    local vHolder = Instance.new("Folder", Holder)
    vHolder.Name = v.Name
    v.CharacterAdded:Connect(function() pcall(LoadCharacter, v) end)
    v.CharacterRemoving:Connect(function() pcall(UnloadCharacter, v) end)
    pcall(LoadCharacter, v)
end

local UnloadPlayer = function(v)
    UnloadCharacter(v)
    local vHolder = Holder:FindFirstChild(v.Name)
    if vHolder then vHolder:Destroy() end
end

for i,v in pairs(players:GetPlayers()) do
    if v ~= plr then task.spawn(function() pcall(LoadPlayer, v) end) end
end

players.PlayerAdded:Connect(function(v) pcall(LoadPlayer, v) end)
players.PlayerRemoving:Connect(function(v) pcall(UnloadPlayer, v) end)
plr.NameDisplayDistance = 0

task.spawn(function()
    while task.wait() do
        for i, v in pairs(players:GetPlayers()) do
            local esp = getESP(v)
            
            if v ~= plr and v.Character and v.Character:FindFirstChild("HumanoidRootPart") and v.Character:FindFirstChild("Humanoid") then
                local hrp = v.Character.HumanoidRootPart
                local screenPos, onScreen = camera:WorldToViewportPoint(hrp.Position)
                
                if v.Character:FindFirstChild("GetReal") then
                    v.Character.GetReal:Destroy()
                end
                
                if onScreen then
                    local head = v.Character:FindFirstChild("Head")
                    local headPos = head and camera:WorldToViewportPoint(head.Position + Vector3.new(0, 0.5, 0)) or screenPos
                    local legPos = camera:WorldToViewportPoint(hrp.Position - Vector3.new(0, 3, 0))
                    
                    local boxHeight = math.abs(headPos.Y - legPos.Y)
                    local boxWidth = boxHeight / 1.5
                    
                    if _G.ShowBoxes then
                        esp.Box.Size = Vector2.new(boxWidth, boxHeight)
                        esp.Box.Position = Vector2.new(screenPos.X - boxWidth / 2, screenPos.Y - boxHeight / 2)
                        esp.Box.Color = _G.ESPColor
                        esp.Box.Visible = true
                    else
                        esp.Box.Visible = false
                    end
                    
                    if _G.ShowTracers then
                        esp.Tracer.Color = _G.ESPColor
                        esp.Tracer.From = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y)
                        esp.Tracer.To = Vector2.new(screenPos.X, screenPos.Y)
                        esp.Tracer.Visible = true
                    else
                        esp.Tracer.Visible = false
                    end
                    
                    local vHolder = Holder:FindFirstChild(v.Name)
                    if vHolder then
                        local nameTag = vHolder:FindFirstChild(v.Name .. "NameTag")
                        if nameTag then
                            nameTag.Enabled = _G.ShowNames
                            local targetTag = nameTag:FindFirstChild("TargetTag")
                            if targetTag and _G.ShowNames then
                                updateTagText(v, targetTag)
                            end
                        end
                    end
                else
                    esp.Box.Visible = false
                    esp.Tracer.Visible = false
                    local vHolder = Holder:FindFirstChild(v.Name)
                    if vHolder and vHolder:FindFirstChild(v.Name .. "NameTag") then
                        vHolder[v.Name .. "NameTag"].Enabled = false
                    end
                end
            else
                esp.Box.Visible = false
                esp.Tracer.Visible = false
            end
        end
    end
end)
