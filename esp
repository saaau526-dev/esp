local function createRowComponent(text, globalVar)
    local RowFrame = Instance.new("Frame", MainPanel)
    RowFrame.Size = UDim2.new(0, 205, 0, 34)
    RowFrame.BackgroundTransparency = 1
    
    local btn = Instance.new("TextButton", RowFrame)
    btn.Size = UDim2.new(0, 160, 0, 34)
    btn.Position = UDim2.new(0, 0, 0, 0)
    btn.Font = Enum.Font.RobotoMono
    btn.TextSize = 11
    btn.BorderSizePixel = 0
    
    local btnCorner = Instance.new("UICorner", btn)
    btnCorner.CornerRadius = UDim.new(0, 6)
    
    local btnStroke = Instance.new("UIStroke", btn)
    btnStroke.Thickness = 1

    -- 横に設置するカラープレビューボックス
    local ColorIndicator = Instance.new("TextButton", RowFrame)
    ColorIndicator.Size = UDim2.new(0, 38, 0, 34)
    ColorIndicator.Position = UDim2.new(0, 167, 0, 0)
    ColorIndicator.Text = ""
    ColorIndicator.BorderSizePixel = 0
    
    local indCorner = Instance.new("UICorner", ColorIndicator)
    indCorner.CornerRadius = UDim.new(0, 6)
    
    local indStroke = Instance.new("UIStroke", ColorIndicator)
    indStroke.Thickness = 1.5

    local function updateDisplay()
        -- ON/OFF 見た目の処理
        if _G[globalVar] then
            btn.BackgroundColor3 = Color3.fromRGB(240, 240, 245)
            btn.TextColor3 = Color3.fromRGB(15, 15, 15)
            btn.Text = text .. " : ON"
        else
            btn.BackgroundColor3 = Color3.fromRGB(28, 28, 32)
            btn.TextColor3 = Color3.fromRGB(130, 130, 135)
            btn.Text = text .. " : OFF"
        end

        -- 現在選択されているカラー調整対象の枠線を強調
        if currentConfigTarget == globalVar then
            btnStroke.Color = Color3.fromRGB(255, 255, 255)
            btnStroke.Transparency = 0.1
            indStroke.Color = Color3.fromRGB(255, 255, 255)
            indStroke.Transparency = 0.1
        else
            btnStroke.Color = Color3.fromRGB(55, 55, 60)
            btnStroke.Transparency = 0.6
            indStroke.Color = Color3.fromRGB(40, 40, 45)
            indStroke.Transparency = 0.4
        end

        ColorIndicator.BackgroundColor3 = _G.Colors[globalVar]
    end
    
    -- メインボタンクリック：ON/OFF切り替え ＆ カラー編集ターゲットに設定
    btn.MouseButton1Click:Connect(function()
        _G[globalVar] = not _G[globalVar]
        currentConfigTarget = globalVar
        updateDisplay()
        saveConfig()
    end)

    -- インジケータークリック：カラー編集ターゲットに設定
    ColorIndicator.MouseButton1Click:Connect(function()
        currentConfigTarget = globalVar
        updateDisplay()
    end)
    
    task.spawn(function()
        while task.wait(0.2) do
            updateDisplay()
        end
    end)

    updateDisplay()
end

